datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String    @id @default(uuid())
  username  String    @unique
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  logs      GameLog[]
}

model GameLog {
  id            String    @id @default(uuid())
  userId        String
  rawgGameId    Int
  gameTitle     String
  gameCoverUrl  String?
  genres        String?   // Comma-separated genre names e.g. "Action, RPG, Adventure"
  status        String // BACKLOG, PLAYING, COMPLETED, ON_HOLD, DROPPED
  rating        Float?
  playtimeHours Float     @default(0)
  review        String?
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, rawgGameId])
}
